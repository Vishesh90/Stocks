# ─────────────────────────────────────────────────────
# BROKER — DHAN (historical data + live execution)
# ─────────────────────────────────────────────────────
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────
# BROKER — GROWW (live execution)
# ─────────────────────────────────────────────────────
GROWW_API_KEY=
GROWW_API_SECRET=

# ─────────────────────────────────────────────────────
# RISK PARAMETERS
# ─────────────────────────────────────────────────────
DAILY_LOSS_LIMIT_INR=500
MAX_TRADES_PER_DAY=10
CAPITAL_INR=20000
RISK_PER_TRADE_PCT=0.015

# ─────────────────────────────────────────────────────
# EXECUTION MODE
# paper = log orders only, no real execution
# live  = real money via broker API
# ─────────────────────────────────────────────────────
EXECUTION_MODE=paper

# ─────────────────────────────────────────────────────
# DATA
# ─────────────────────────────────────────────────────
DATA_CACHE_DIR=data/cache
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed

# ─────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
REPORTS_DIR=reports
